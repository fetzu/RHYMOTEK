---
import { getCollection } from 'astro:content';
import VerseLayout from '../../layouts/VerseLayout.astro';
import VerseDisplay from '../../components/VerseDisplay.astro';
import VerseInteractive from '../../components/VerseInteractive';

export async function getStaticPaths() {
  const verses = await getCollection('verses');
  return verses.map((verse) => ({
    params: { slug: verse.data.slug },
    props: { verse },
  }));
}

const { verse } = Astro.props;
const { title, artist, album, year, backgroundColor, textColor, accentColor, lines, tags, analysisGroups } = verse.data;
const verseText = lines.map((l) => l.words.map((w) => w.text).join(' ')).join(' / ');
---

<VerseLayout
  title={title}
  artist={artist}
  backgroundColor={backgroundColor}
  textColor={textColor}
  accentColor={accentColor}
>
  <div data-pagefind-body>
    <div data-pagefind-meta={`title:${title}`}></div>
    <div data-pagefind-meta={`artist:${artist}`}></div>
    {album && <div data-pagefind-meta={`album:${album}`}></div>}
    {year && <div data-pagefind-meta={`year:${year}`}></div>}
    {tags?.map((tag: string) => <div data-pagefind-filter={`tag:${tag}`}></div>)}
    <div data-pagefind-filter={`artist:${artist}`}></div>
    <VerseDisplay lines={lines} />
  </div>
  <VerseInteractive
    client:idle
    analysisGroups={analysisGroups as any}
    accentColor={accentColor}
  />
</VerseLayout>
