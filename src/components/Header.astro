---
interface Props {
  textColor?: string;
}

const { textColor } = Astro.props;
const style = textColor ? `color: ${textColor};` : '';
---

<header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4">
  <a
    href="/"
    class="font-display text-lg font-bold tracking-tight opacity-70 hover:opacity-100 transition-opacity"
    style={style}
  >
    RHYMOTEK
  </a>
  <nav class="flex items-center gap-4">
    <a
      href="/search"
      class="text-sm font-body opacity-60 hover:opacity-100 transition-opacity"
      style={style}
      title="Search verses"
    >
      Search
    </a>
    <a
      href="/random"
      class="text-sm font-body opacity-60 hover:opacity-100 transition-opacity"
      style={style}
      title="Random verse"
    >
      Random
    </a>
  </nav>
</header>
